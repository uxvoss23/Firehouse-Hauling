<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Firehouse Hauling LLC | Firefighter-Owned Junk Removal</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --red: #C1121F;
  --red-dark: #9E0E19;
  --charcoal: #1C1C1C;
  --yellow: #FFD166;
  --off-white: #F7F7F7;
  --white: #FFFFFF;
  --gray: #6B7280;
  --light-gray: #E5E7EB;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Inter', sans-serif; color: var(--charcoal); background: var(--off-white); overflow-x: hidden; }

/* Animations */
@keyframes fadeInUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
@keyframes pulseGlow { 0%,100% { box-shadow:0 0 0 0 rgba(193,18,31,0.4); } 50% { box-shadow:0 0 0 14px rgba(193,18,31,0); } }
@keyframes slideIn { from { opacity:0; transform:translateX(30px); } to { opacity:1; transform:translateX(0); } }

.animate-on-scroll { opacity:1; transform:translateY(0); transition: opacity 0.7s cubic-bezier(.22,1,.36,1), transform 0.7s cubic-bezier(.22,1,.36,1); }
.animate-on-scroll.visible { opacity:1; transform:translateY(0); }
.js-animations .animate-on-scroll { opacity:0; transform:translateY(36px); }
.js-animations .animate-on-scroll.visible { opacity:1; transform:translateY(0); }
.no-observer .animate-on-scroll { opacity:1; transform:none; }

/* Buttons */
.btn-primary {
  display:inline-flex; align-items:center; gap:8px;
  padding:14px 32px; background:var(--red); color:white;
  font-family:'Bebas Neue',sans-serif; font-size:18px; letter-spacing:1.5px;
  border:none; border-radius:8px; cursor:pointer; text-decoration:none;
  transition:all 0.25s ease;
}
.btn-primary:hover { background:var(--red-dark); transform:translateY(-2px); box-shadow:0 6px 20px rgba(193,18,31,0.35); }
.btn-outline {
  display:inline-flex; align-items:center; gap:8px;
  padding:14px 32px; background:transparent; color:white;
  font-family:'Bebas Neue',sans-serif; font-size:18px; letter-spacing:1.5px;
  border:2px solid white; border-radius:8px; cursor:pointer; text-decoration:none;
  transition:all 0.25s ease;
}
.btn-outline:hover { background:white; color:var(--charcoal); transform:translateY(-2px); }
.btn-white { background:white; color:var(--red); }
.btn-white:hover { background:#f0f0f0; }

/* Header */
.header {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  transition:all 0.35s ease;
}
.header.scrolled { background:rgba(28,28,28,0.97); backdrop-filter:blur(12px); border-bottom:1px solid rgba(255,255,255,0.08); }
.header-inner {
  max-width:1200px; margin:0 auto; padding:0 24px;
  display:flex; align-items:center; justify-content:space-between; height:76px;
  transition:height 0.35s ease; position:relative;
}
.header.scrolled .header-inner { height:64px; }
.logo { display:flex; align-items:center; gap:10px; text-decoration:none; }
.logo-icon { width:36px; height:36px; border-radius:8px; background:var(--red); display:flex; align-items:center; justify-content:center; color:white; }
.logo-text { font-family:'Bebas Neue',sans-serif; font-size:22px; color:white; letter-spacing:2px; }
.nav { display:flex; gap:32px; align-items:center; }
.nav-link { color:rgba(255,255,255,0.8); text-decoration:none; font-size:14px; font-weight:500; letter-spacing:0.5px; transition:color 0.2s; background:none; border:none; cursor:pointer; font-family:'Inter',sans-serif; }
.nav-link:hover { color:var(--yellow); }
.nav .btn-primary { padding:10px 24px; font-size:15px; }
.mobile-toggle { display:none; background:none; border:none; color:white; cursor:pointer; position:absolute; right:24px; top:50%; transform:translateY(-50%); }
.mobile-menu { display:none; background:var(--charcoal); flex-direction:column; border-bottom:2px solid var(--red); }
.mobile-menu.open { display:flex; }
.mobile-menu-links { display:flex; flex-direction:column; padding:8px 24px 20px; }
.mobile-menu-links button { background:none; border:none; color:rgba(255,255,255,0.9); font-family:'Inter',sans-serif; font-size:17px; padding:14px 0; text-align:left; cursor:pointer; border-bottom:1px solid rgba(255,255,255,0.1); }
.mobile-menu-close-row { display:flex; justify-content:flex-end; padding:8px 16px 0; }
.mobile-menu-close-row button { background:none; border:none; color:rgba(255,255,255,0.7); cursor:pointer; padding:8px; font-family:'Inter',sans-serif; font-size:14px; display:flex; align-items:center; gap:6px; }

@media(max-width:768px) {
  .nav { display:none !important; }
  .mobile-toggle { display:block !important; }
  .hero-buttons { flex-direction:column; }
  .hero-buttons a, .hero-buttons .btn-primary { width:100%; justify-content:center; text-align:center; }
  
  /* Reduce section padding on mobile */
  .section { padding:48px 16px; }
  .services-section { padding:48px 16px; }
  .why-section { padding:48px 16px; }
  .reviews-section { padding:48px 16px; }
  .cta-section { padding:48px 16px; }
  
  /* Fix grids for mobile - single column */
  .steps-grid { grid-template-columns:1fr; gap:24px; margin-top:36px; }
  .services-grid { grid-template-columns:1fr; gap:16px; }
  .why-grid { grid-template-columns:1fr; gap:20px; }
  .area-grid { grid-template-columns:1fr 1fr; gap:12px; margin-top:32px; }
  .contact-grid { grid-template-columns:1fr; gap:32px; }
  
  /* Smaller hero on mobile */
  .hero { min-height:auto; }
  .hero-content { padding:100px 16px 60px; }
  .hero h1 { font-size:clamp(36px,10vw,52px); }
  .trust-row { gap:16px; margin-top:32px; }
  .trust-item span { font-size:11px; }
  .hero-fade { height:60px; }
  
  /* Trust badge bar - prominent on mobile */
  .trust-bar { flex-direction:row; flex-wrap:wrap; gap:12px 24px; justify-content:center; padding:20px 16px; }
  .trust-bar-item svg { width:24px; height:24px; flex-shrink:0; }
  .trust-bar-title { font-size:15px; }
  .trust-bar-sub { font-size:10px; }
  
  /* Section titles smaller on mobile */
  .section-title { font-size:clamp(28px,8vw,40px); }
  
  /* Review card padding */
  .review-card { padding:32px 20px; }
  .review-text { font-size:15px; }
  
  /* CTA section */
  .cta-section h2 { font-size:clamp(32px,8vw,48px); }
  .cta-buttons { flex-direction:column; align-items:center; }
  .cta-buttons a { width:100%; justify-content:center; text-align:center; max-width:320px; }
  
  /* Form card */
  .form-card { padding:28px 20px; }
  
  /* Before/after smaller */
  .ba-container { max-width:100%; }
  
  /* Floating phone smaller and out of the way */
  .floating-phone { width:52px; height:52px; bottom:16px; right:16px; }

  /* Step cards less padding */
  .step-card { padding:32px 20px; }
  .service-card { padding:24px 20px; }
  .why-card { padding:32px 20px; }
  
  /* Contact section text alignment */
  .contact-grid .section-label { text-align:center !important; }
  .contact-grid .section-title { text-align:center !important; }
  
  /* Hero logo smaller on mobile */
  .hero-logo { width:100px !important; height:100px !important; }
}

/* Hero */
.hero {
  position:relative; min-height:100vh; display:flex; align-items:center;
  background:linear-gradient(135deg, var(--charcoal) 0%, #2a1a1a 50%, var(--charcoal) 100%);
  overflow:hidden;
}
.hero-stripes { position:absolute; inset:0; opacity:0.03; background-image:repeating-linear-gradient(45deg,transparent,transparent 20px,white 20px,white 21px); }
.hero-glow { position:absolute; top:-30%; right:-10%; width:60%; height:80%; background:radial-gradient(ellipse,rgba(193,18,31,0.13) 0%,transparent 70%); }
.hero-content { max-width:1200px; margin:0 auto; padding:90px 24px 50px; width:100%; position:relative; z-index:1; }
.hero-inner { max-width:700px; }
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(193,18,31,0.15); border:1px solid rgba(193,18,31,0.27);
  border-radius:100px; padding:8px 20px; margin-bottom:28px;
  animation:fadeInUp 0.6s ease both;
}
.hero-badge span { color:var(--yellow); font-weight:600; font-size:13px; letter-spacing:1.5px; text-transform:uppercase; }
.hero h1 {
  font-family:'Bebas Neue',sans-serif; font-size:clamp(42px,7vw,80px);
  color:white; line-height:1.05; letter-spacing:2px; animation:fadeInUp 0.6s ease 0.15s both;
}
.hero h1 span { color:var(--red); }
.hero p { font-size:clamp(17px,2.2vw,21px); color:rgba(255,255,255,0.7); margin-top:20px; line-height:1.6; max-width:520px; animation:fadeInUp 0.6s ease 0.3s both; }
.hero-buttons { display:flex; gap:16px; margin-top:36px; flex-wrap:wrap; animation:fadeInUp 0.6s ease 0.45s both; }
.hero-buttons .btn-primary { font-size:20px; padding:16px 40px; }
.hero-buttons .btn-outline { font-size:20px; padding:16px 40px; }
.trust-row { display:flex; gap:32px; margin-top:52px; flex-wrap:wrap; animation:fadeInUp 0.6s ease 0.6s both; }
.trust-item { display:flex; align-items:center; gap:10px; color:rgba(255,255,255,0.6); }
.trust-item svg { color:var(--yellow); }
.trust-item span { font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; }
.hero-fade { position:absolute; bottom:0; left:0; right:0; height:120px; background:linear-gradient(to top,var(--off-white),transparent); }

/* Trust Badge Bar */
.trust-bar {
  display:flex; justify-content:center; gap:40px; padding:24px 20px;
  background:#fff; border-bottom:1px solid var(--light-gray);
  box-shadow:0 2px 12px rgba(0,0,0,0.04);
}
.trust-bar-item { display:flex; align-items:center; gap:12px; }
.trust-bar-title { font-family:'Bebas Neue',sans-serif; font-size:17px; letter-spacing:1px; color:var(--charcoal); line-height:1.1; }
.trust-bar-sub { font-size:11px; color:var(--gray); font-weight:500; }

/* Section Basics */
.section { padding:80px 24px; max-width:1200px; margin:0 auto; }
.section-label { color:var(--red); font-weight:700; font-size:13px; letter-spacing:3px; text-transform:uppercase; display:block; text-align:center; }
.section-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(36px,5vw,52px); margin-top:8px; letter-spacing:1.5px; text-align:center; }

/* How It Works */
.steps-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:32px; margin-top:56px; }
.step-card {
  background:white; border-radius:20px; padding:40px 28px; text-align:center;
  border:1px solid var(--light-gray); position:relative; box-shadow:0 2px 12px rgba(0,0,0,0.04);
}
.step-badge {
  position:absolute; top:-1px; left:50%; transform:translateX(-50%);
  background:var(--red); color:white; font-family:'Bebas Neue',sans-serif;
  font-size:14px; letter-spacing:2px; padding:4px 20px; border-radius:0 0 8px 8px;
}
.step-icon {
  width:72px; height:72px; border-radius:50%; margin:16px auto 20px;
  background:rgba(193,18,31,0.05); color:var(--red);
  display:flex; align-items:center; justify-content:center;
}
.step-card h3 { font-family:'Bebas Neue',sans-serif; font-size:24px; letter-spacing:1px; margin-bottom:10px; }
.step-card p { color:var(--gray); line-height:1.7; font-size:15px; }

/* Services */
.services-section { padding:80px 24px; background:linear-gradient(180deg,var(--off-white) 0%,#f0f0f0 100%); }
.services-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:24px; max-width:1200px; margin:56px auto 0; }
.service-card {
  background:white; border-radius:16px; padding:32px 24px; text-align:center;
  box-shadow:0 2px 12px rgba(0,0,0,0.06); border:1px solid var(--light-gray);
  transition:all 0.3s ease; height:100%;
}
.service-card:hover { transform:translateY(-6px); box-shadow:0 12px 40px rgba(0,0,0,0.1); border-color:var(--red); }
.service-icon {
  width:56px; height:56px; border-radius:14px; margin:0 auto 16px;
  background:rgba(193,18,31,0.05); color:var(--red);
  display:flex; align-items:center; justify-content:center;
}
.service-card h3 { font-family:'Bebas Neue',sans-serif; font-size:21px; letter-spacing:0.8px; margin-bottom:10px; }
.service-card p { color:var(--gray); font-size:14px; line-height:1.7; }

/* Why Choose Us */
.why-section {
  padding:80px 24px; background:var(--charcoal); color:white;
  position:relative; overflow:hidden;
}
.why-section .stripes { position:absolute; inset:0; opacity:0.04; background-image:repeating-linear-gradient(45deg,transparent,transparent 20px,white 20px,white 21px); }
.why-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:32px; max-width:1200px; margin:56px auto 0; position:relative; }
.why-card {
  background:rgba(255,255,255,0.05); border-radius:20px; padding:40px 28px;
  border:1px solid rgba(255,255,255,0.08); text-align:center; transition:all 0.3s ease;
}
.why-card:hover { background:rgba(255,255,255,0.08); }
.why-icon {
  width:64px; height:64px; border-radius:50%; margin:0 auto 20px;
  background:rgba(193,18,31,0.13); color:var(--yellow);
  display:flex; align-items:center; justify-content:center;
}
.why-card h3 { font-family:'Bebas Neue',sans-serif; font-size:24px; letter-spacing:1px; margin-bottom:12px; }
.why-card p { color:rgba(255,255,255,0.6); line-height:1.7; font-size:15px; }

/* Before/After */
.ba-container {
  position:relative; width:100%; max-width:600px; aspect-ratio:4/3;
  border-radius:16px; overflow:hidden; cursor:ew-resize;
  box-shadow:0 8px 32px rgba(0,0,0,0.18); margin:0 auto; user-select:none;
  -webkit-user-select:none; touch-action:none;
}
.ba-after, .ba-before {
  position:absolute; inset:0; background-size:cover; background-position:center;
}
/* AFTER: clean garage scene */
.ba-after {
  background: linear-gradient(180deg, #d4d4d4 0%, #bdbdbd 40%, #9e9e9e 40.5%, #8a8a8a 100%);
}
.ba-after-overlay {
  position:absolute; inset:0; display:flex; align-items:center; justify-content:center; flex-direction:column;
  background: rgba(200,230,201,0.15);
}
/* BEFORE: cluttered garage scene */
.ba-before {
  background: linear-gradient(180deg, #8d7b68 0%, #a08c78 35%, #6d5d4b 35.5%, #5a4a3a 100%);
}
.ba-before-overlay {
  position:absolute; inset:0; display:flex; align-items:center; justify-content:center; flex-direction:column;
  background: rgba(141,123,104,0.2);
}
.ba-tag {
  font-family:'Bebas Neue',sans-serif; font-size:18px; letter-spacing:3px;
  padding:6px 20px; border-radius:6px; position:absolute; bottom:16px;
}
.ba-tag-after { right:16px; background:rgba(46,125,50,0.9); color:white; }
.ba-tag-before { left:16px; background:rgba(93,64,55,0.9); color:white; }
.ba-line { position:absolute; top:0; bottom:0; width:3px; background:white; transform:translateX(-50%); box-shadow:0 0 8px rgba(0,0,0,0.3); z-index:5; }
.ba-handle {
  position:absolute; top:50%; transform:translate(-50%,-50%); z-index:6;
  width:44px; height:44px; border-radius:50%; background:white;
  box-shadow:0 2px 12px rgba(0,0,0,0.25);
  display:flex; align-items:center; justify-content:center;
  font-size:18px; color:var(--charcoal);
}
.ba-img { width:100%; height:100%; object-fit:cover; display:block; }

/* Reviews */
.reviews-section { padding:80px 24px; background:linear-gradient(180deg,#f0f0f0 0%,var(--off-white) 100%); }
.review-card {
  background:white; border-radius:24px; padding:48px 36px;
  box-shadow:0 4px 24px rgba(0,0,0,0.06); border:1px solid var(--light-gray);
  text-align:center; max-width:800px; margin:0 auto;
}
.stars { display:flex; justify-content:center; gap:4px; margin-bottom:20px; }
.star { color:var(--yellow); }
.review-text { font-size:18px; line-height:1.8; color:var(--charcoal); font-style:italic; max-width:560px; margin:0 auto; }
.review-name { margin-top:20px; font-weight:700; font-size:15px; color:var(--red); }
.review-nav { display:flex; justify-content:center; gap:8px; margin-top:24px; align-items:center; }
.review-arrow {
  width:40px; height:40px; border-radius:50%; border:1px solid var(--light-gray);
  background:white; cursor:pointer; display:flex; align-items:center; justify-content:center;
  transition:all 0.2s;
}
.review-arrow:hover { border-color:var(--red); }
.review-dot { width:10px; height:10px; border-radius:50%; border:none; cursor:pointer; transition:background 0.3s; }

/* Service Area */
.area-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:20px; max-width:700px; margin:48px auto 0; }
.area-card {
  display:flex; align-items:center; gap:12px;
  background:white; border-radius:14px; padding:20px 24px;
  box-shadow:0 2px 8px rgba(0,0,0,0.05); border:1px solid var(--light-gray); transition:all 0.3s;
}
.area-card:hover { transform:translateY(-3px); box-shadow:0 6px 20px rgba(0,0,0,0.1); }
.area-card svg { color:var(--red); flex-shrink:0; }
.area-card span { font-family:'Bebas Neue',sans-serif; font-size:20px; letter-spacing:1px; }

/* CTA */
.cta-section {
  padding:80px 24px; background:var(--red); text-align:center;
  position:relative; overflow:hidden;
}
.cta-section .stripes { position:absolute; inset:0; opacity:0.08; background-image:repeating-linear-gradient(-45deg,transparent,transparent 20px,white 20px,white 21px); }
.cta-section h2 { font-family:'Bebas Neue',sans-serif; font-size:clamp(40px,6vw,64px); color:white; letter-spacing:2px; position:relative; }
.cta-section p { color:rgba(255,255,255,0.8); font-size:18px; margin-top:12px; position:relative; }
.cta-buttons { display:flex; gap:16px; justify-content:center; margin-top:36px; flex-wrap:wrap; position:relative; }

/* Contact */
.contact-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:48px; }
.contact-info a { display:flex; align-items:center; gap:14px; text-decoration:none; color:var(--charcoal); margin-bottom:20px; }
.contact-icon {
  width:48px; height:48px; border-radius:12px; background:rgba(193,18,31,0.05);
  color:var(--red); display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.contact-label { font-size:12px; color:var(--gray); font-weight:600; letter-spacing:1px; text-transform:uppercase; }
.contact-value { font-size:17px; font-weight:600; }
.form-card {
  background:white; border-radius:24px; padding:40px 32px;
  box-shadow:0 4px 24px rgba(0,0,0,0.06); border:1px solid var(--light-gray);
}
.form-card h3 { font-family:'Bebas Neue',sans-serif; font-size:28px; letter-spacing:1px; margin-bottom:24px; }
.form-group { margin-bottom:16px; }
.form-group label { font-size:13px; font-weight:600; color:var(--gray); display:block; margin-bottom:6px; }
input, textarea {
  width:100%; padding:14px 16px; border:2px solid var(--light-gray);
  border-radius:10px; font-family:'Inter',sans-serif; font-size:15px;
  transition:border-color 0.2s; outline:none; background:white;
}
input:focus, textarea:focus { border-color:var(--red); }
textarea { resize:vertical; min-height:100px; }
.form-note { text-align:center; font-size:12px; color:var(--gray); margin-top:12px; }

/* Footer */
.footer { background:var(--charcoal); color:rgba(255,255,255,0.5); padding:48px 24px 32px; }
.footer-inner {
  max-width:1200px; margin:0 auto; display:flex; flex-wrap:wrap;
  justify-content:space-between; align-items:center; gap:24px;
}
.footer-logo { display:flex; align-items:center; gap:10px; }
.footer-logo-icon { width:32px; height:32px; border-radius:6px; background:var(--red); display:flex; align-items:center; justify-content:center; color:white; }
.footer-logo span { font-family:'Bebas Neue',sans-serif; font-size:18px; color:rgba(255,255,255,0.8); letter-spacing:2px; }
.footer-info { font-size:13px; }

/* Floating Phone */
.floating-phone {
  position:fixed; bottom:24px; right:24px; z-index:999;
  width:60px; height:60px; border-radius:50%;
  background:var(--red); color:white;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(193,18,31,0.4);
  animation:pulseGlow 2s infinite; cursor:pointer;
  border:none; text-decoration:none;
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header" id="mainHeader">
  <div class="header-inner">
    <div class="logo" style="cursor:default;">
      <img src="data:image/png;base64," alt="Firehouse Hauling Logo" style="width:44px;height:44px;border-radius:8px;object-fit:contain;">
      <span class="logo-text">FIREHOUSE HAULING</span>
    </a>
    <nav class="nav">
      <a href="javascript:void(0)" onclick="scrollToSection('services')" class="nav-link">Services</a>
      <a href="javascript:void(0)" onclick="scrollToSection('how')" class="nav-link">How It Works</a>
      <a href="javascript:void(0)" onclick="scrollToSection('reviews')" class="nav-link">Reviews</a>
